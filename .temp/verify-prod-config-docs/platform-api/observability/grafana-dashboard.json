{
  "title": "OpenClaw Platform API",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(openclaw_http_requests_total[5m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "P95 Latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(openclaw_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "In Flight Requests",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "openclaw_http_in_flight_requests"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx Rate",
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(openclaw_http_requests_total{status=~\"Internal Server Error|Bad Gateway\"}[5m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ]
    }
  ]
}

