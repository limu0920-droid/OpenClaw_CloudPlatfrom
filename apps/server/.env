PORT=8080

PLATFORM_STRICT_MODE=false

# 禁用数据库和其他外部依赖
DATABASE_URL=
AUTO_MIGRATE=false
AUTO_BOOTSTRAP=false

# 禁用运行时提供者
RUNTIME_PROVIDER=

# 工作区桥接配置
WORKSPACE_BRIDGE_PATH=/api/v1/platform/workspace/messages
WORKSPACE_BRIDGE_HEALTH_PATH=/api/v1/platform/workspace/health
WORKSPACE_BRIDGE_HISTORY_PATH=/api/v1/platform/workspace/sessions/{sessionNo}/history
WORKSPACE_BRIDGE_STREAM_PATH=/api/v1/platform/workspace/sessions/{sessionNo}/stream
WORKSPACE_BRIDGE_REPORT_PATH=/api/v1/platform/workspace/report
WORKSPACE_BRIDGE_HEADER_NAME=X-Platform-Bridge-Token
WORKSPACE_BRIDGE_TOKEN=dev-token
WORKSPACE_BRIDGE_PUBLIC_BASE_URL=http://localhost:8080
WORKSPACE_BRIDGE_TIMEOUT_SECS=10
WORKSPACE_BRIDGE_RETRY_COUNT=2
WORKSPACE_BRIDGE_RETRY_BACKOFF_MS=250
WORKSPACE_BRIDGE_HISTORY_SYNC=true

# 禁用对象存储
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=

# 产物预览配置
ARTIFACT_PREVIEW_TIMEOUT_SECS=30
ARTIFACT_PREVIEW_HTML_MAX_BYTES=2097152
ARTIFACT_PREVIEW_ALLOW_PRIVATE_IP=true
ARTIFACT_PREVIEW_PUBLIC_BASE_URL=http://localhost:8080

# 认证配置（本地开发）
KEYCLOAK_ENABLED=false
KEYCLOAK_SESSION_SECRET=dev-secret
KEYCLOAK_COOKIE_NAME=openclaw_auth
KEYCLOAK_FLOW_COOKIE_NAME=openclaw_auth_flow
KEYCLOAK_COOKIE_SECURE=false

# 禁用搜索
OPENSEARCH_ENABLED=false

# 禁用追踪
TRACE_SEARCH_ENABLED=false

# 禁用微信支付
WECHATPAY_ENABLED=false

# 禁用微信登录
WECHAT_LOGIN_ENABLED=false
