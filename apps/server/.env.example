PORT=8080

PLATFORM_STRICT_MODE=true

# `cmd/server` 现在只允许连接真实数据库启动。
DATABASE_URL=
AUTO_MIGRATE=false
# 如需初始化数据库，请显式运行 `go run ./cmd/bootstrap`。
AUTO_BOOTSTRAP=false
# 如需在启动时把对外文档写到指定目录，填写绝对或相对路径。
EXTERNAL_DOCS_OUTPUT_DIR=

# `cmd/server` 默认要求真实 runtime provider。
RUNTIME_PROVIDER=kubectl
RUNTIME_KUBECTL_BINARY=kubectl
RUNTIME_KUBE_CONTEXT=
RUNTIME_NAMESPACE_PREFIX=openclaw
RUNTIME_WORKLOAD_PREFIX=openclaw
RUNTIME_IMAGE=ghcr.io/openclaw/openclaw:latest
RUNTIME_SERVICE_TYPE=NodePort
RUNTIME_ACCESS_HOST=localhost
RUNTIME_ACCESS_SCHEME=http
RUNTIME_PORT=18789
WORKSPACE_BRIDGE_PATH=/api/v1/platform/workspace/messages
WORKSPACE_BRIDGE_HEALTH_PATH=/api/v1/platform/workspace/health
WORKSPACE_BRIDGE_HISTORY_PATH=/api/v1/platform/workspace/sessions/{sessionNo}/history
WORKSPACE_BRIDGE_STREAM_PATH=/api/v1/platform/workspace/sessions/{sessionNo}/stream
WORKSPACE_BRIDGE_REPORT_PATH=/api/v1/platform/workspace/report
WORKSPACE_BRIDGE_HEADER_NAME=X-Platform-Bridge-Token
WORKSPACE_BRIDGE_TOKEN=
WORKSPACE_BRIDGE_PUBLIC_BASE_URL=http://localhost:8080
WORKSPACE_BRIDGE_TIMEOUT_SECS=10
WORKSPACE_BRIDGE_RETRY_COUNT=2
WORKSPACE_BRIDGE_RETRY_BACKOFF_MS=250
WORKSPACE_BRIDGE_HISTORY_SYNC=true
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=openclaw-dev
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_FORCE_PATH_STYLE=true
# 正式环境建议使用独立 preview 子域名指向同一套 platform-api 服务。
ARTIFACT_PREVIEW_TIMEOUT_SECS=30
ARTIFACT_PREVIEW_HTML_MAX_BYTES=2097152
# 仅本地联调时才允许代理私网地址。
ARTIFACT_PREVIEW_ALLOW_PRIVATE_IP=false
ARTIFACT_PREVIEW_PUBLIC_BASE_URL=http://localhost:8080
# 额外允许的可信产物域名，多个值用逗号分隔；不要填 *。
ARTIFACT_PREVIEW_ALLOWED_HOSTS=

KEYCLOAK_ENABLED=false
KEYCLOAK_BASE_URL=https://sso.example.com
KEYCLOAK_REALM=openclaw
KEYCLOAK_CLIENT_ID=openclaw-portal
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URL=http://localhost:5173/login
KEYCLOAK_POST_LOGIN_REDIRECT_URL=http://localhost:5173/portal
KEYCLOAK_LOGOUT_REDIRECT_URL=http://localhost:5173/login
# 真实后端模式下必须留空。
KEYCLOAK_MOCK_USER=
KEYCLOAK_MOCK_EMAIL=
KEYCLOAK_MOCK_ROLE=
KEYCLOAK_SESSION_SECRET=change-me-dev-secret
KEYCLOAK_COOKIE_NAME=openclaw_auth
KEYCLOAK_FLOW_COOKIE_NAME=openclaw_auth_flow
KEYCLOAK_COOKIE_SECURE=false

OPENSEARCH_ENABLED=false
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=openclaw-logs
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# 可选的 trace/span 检索后端，默认可与日志后端共用同一套 OpenSearch 集群。
TRACE_SEARCH_ENABLED=false
TRACE_SEARCH_URL=http://localhost:9200
TRACE_SEARCH_INDEX=openclaw-traces
TRACE_SEARCH_USERNAME=
TRACE_SEARCH_PASSWORD=
# 如需从前端跳到外部 tracing 控制台，请配置为可公开访问的跳转基址。
TRACE_SEARCH_PUBLIC_BASE_URL=

WECHATPAY_ENABLED=false
WECHATPAY_BASE_URL=https://api.mch.weixin.qq.com
WECHATPAY_MCH_ID=
WECHATPAY_APP_ID=
WECHATPAY_CLIENT_SECRET=
WECHATPAY_NOTIFY_URL=http://localhost:8080/api/v1/callback/payment/wechatpay
WECHATPAY_REFUND_NOTIFY_URL=http://localhost:8080/api/v1/callback/payment/wechatpay
WECHATPAY_SERIAL_NO=
WECHATPAY_PUBLIC_KEY_ID=
WECHATPAY_PUBLIC_KEY_PEM=
WECHATPAY_PRIVATE_KEY_PEM=
WECHATPAY_APIV3_KEY=
WECHATPAY_MODE=merchant
WECHATPAY_SUB_MCH_ID=
WECHATPAY_SUB_APP_ID=

WECHAT_LOGIN_ENABLED=false
WECHAT_LOGIN_OPEN_BASE_URL=https://open.weixin.qq.com
WECHAT_LOGIN_API_BASE_URL=https://api.weixin.qq.com
WECHAT_LOGIN_APP_ID=
WECHAT_LOGIN_APP_SECRET=
WECHAT_LOGIN_REDIRECT_URL=http://localhost:8080/api/v1/auth/wechat/callback
# 真实后端模式下必须留空。
WECHAT_LOGIN_MOCK_USER=
WECHAT_LOGIN_MOCK_OPEN_ID=
WECHAT_LOGIN_MOCK_UNION_ID=
